{
  "schemaVersion": 1,
  "id": "dh-carry-helper",
  "version": "${version}",
  "name": "Dungeon Hub Carry Helper",
  "description": "This mod helps you run carries with the Dungeon Hub discord bot.",
  "authors": [
    "Taubsie"
  ],
  "contact": {
    "homepage": "https://dungeon-hub.net/",
    "discord": "https://discord.dungeon-hub.net/",
    "sources": "https://github.com/dungeon-hub/dungeon-hub-carry-helper/"
  },
  "license": "EUPL-1.2",
  "icon": "assets/dh-carry-helper/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "net.dungeonhub.carryhelper.DhCarryHelper"
      }
    ]
  },
  "mixins": [
    {
      "config": "dh-carry-helper.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "resourcefulconfig": ">=4.0.1"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.dungeon-hub.net/"
      }
    }
  }
}
